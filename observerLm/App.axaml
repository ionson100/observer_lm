<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="observerLm.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
             <Application.Resources>
                 <!-- Важно: используйте тип StreamGeometry -->
                 <StreamGeometry x:Key="HomeIconData">M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z</StreamGeometry>
                 <StreamGeometry x:Key="SettingsIconData">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.44,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.56,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.56,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.44,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</StreamGeometry>
             </Application.Resources>
    <Application.Styles>
        <FluentTheme />
     
        <!-- Ваш общий стиль для 3D кнопки -->
        <Style Selector="Button.retro3d">
            <Setter Property="Background" Value="#4a90e2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,4"/>
            <Setter Property="BorderBrush" Value="#2c5e9e"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.05"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.retro3d:pressed">
            <Setter Property="RenderTransform" Value="translateY(2px)"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        
        <Style Selector="ListBox.myList ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#494646" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ListBox.myList ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#494646" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style Selector="TextBox.EditText">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="SelectionBrush" Value="Gray" />
            <Setter Property="SelectionForegroundBrush" Value="White" />
        </Style>
        <Style Selector="TextBox.EditText:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#E7FCEA" />
        </Style>
        
        <Style Selector="Button.primary">
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#125394" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>
        
        <Style Selector="PathIcon.error">
            <Setter Property="Foreground" Value="#E13A43" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Height" Value="25" />
           
        </Style>
        <Style Selector="PathIcon.info">
            <Setter Property="Foreground" Value="#1960FF" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Height" Value="25" />
           
        </Style>
        <Style Selector="PathIcon.warning">
            <Setter Property="Foreground" Value="#F0E958" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Height" Value="25" />
           
        </Style>
        <Style Selector="PathIcon.success">
            <Setter Property="Foreground" Value="#1CCF4F" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Height" Value="25" />
        </Style>
        <Style Selector="PathIcon.confirm">
            <Setter Property="Foreground" Value="#1960FF" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Height" Value="25" />
        </Style>
        
        
        
        
        <Style Selector="TextBox.clean">
            <!-- Убираем рамку -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
    
            <!-- Убираем отступы -->
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
    
            <!-- Прозрачный фон -->
            <Setter Property="Background" Value="Transparent"/>
    
            <!-- Убираем внутреннюю обводку при фокусе -->
            <Setter Property="FocusAdorner" Value="{x:Null}"/>
    
            <!-- Настройки текста -->
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#212121"/>
        </Style>
        
      
   
        
       
        
        
        
        
       

    
        
     
    </Application.Styles>
</Application>